prefix=/usr
includedir=${prefix}/include
libdir=${prefix}/lib/x86_64-linux-gnu

Name: cairo
Description: Multi-platform 2D graphics library
Version: 1.17.7
Requires.private: zlib, libpng, fontconfig >=  2.2.95, freetype2 >=  9.7.3, x11, xext, xrender >=  0.6, xcb >=  1.6, xcb-render >=  1.6, xcb-shm, pixman-1 >=  0.36.0
Libs: -L${libdir} -lcairo
Libs.private: -lm -ldl
Cflags: -I${includedir}/cairo
